{# see WaiBlue\GuideVis\Loader->getPageVars() for the list of available variables #}

<div class="step-by-step">
  {% for stepCnt, step in steps %}
    <div class="step">
      <div class="step-counter">{{ stepCnt }}</div>
      <div class="step-content">
        <div class="step-title">{{ markdown(step.title)|raw }}</div>
        <div class="step-description">{{ markdown(step.description)|raw }}</div>
      </div>
      {% if step.example %} <span class="step-example"><pre>{{ step.example|raw }}</pre></span> {% endif %}
      {% if step.screenshotUrl %}
        <span class="step-screenshot">
          <img class="screenshot" src="{{ env.guideRootUrl }}/screenshots/{{ step.screenshotUrl|replace({'/': '--'}) }}.png" tabindex="1"/>
        </span>
      {% endif %}
    </div>
  {% endfor %}
</div>
